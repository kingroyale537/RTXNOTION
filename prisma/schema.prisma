// =============================================================================
// Voltaic – Prisma Schema
// Database: PostgreSQL
// Features: Multi-workspace, nested pages, real-time collab, RBAC, media
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN   // Full control: manage members, billing, delete workspace
  EDITOR  // Create, edit, delete any page in the workspace
  VIEWER  // Read-only access to published pages
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum PageIconType {
  EMOJI
  URL
  LUCIDE
}

enum ActivityType {
  PAGE_CREATED
  PAGE_UPDATED
  PAGE_DELETED
  PAGE_MOVED
  COMMENT_ADDED
  COMMENT_RESOLVED
  MEMBER_JOINED
  MEMBER_LEFT
  MEMBER_ROLE_CHANGED
}

enum MediaType {
  IMAGE
  VIDEO
  FILE
  AUDIO
}

// ─────────────────────────────────────────────────────────────────────────────
// USER
// Stores both credential and OAuth users. NextAuth adapter writes here.
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // null for OAuth users
  bio           String?   @db.Text
  color         String    @default("#6366f1") // presence cursor color
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // NextAuth relations
  accounts      Account[]
  sessions      Session[]

  // App relations
  workspaceMemberships WorkspaceMember[]
  ownedWorkspaces      Workspace[]       @relation("WorkspaceOwner")
  createdPages         Page[]            @relation("PageCreatedBy")
  lastEditedPages      Page[]            @relation("PageLastEditedBy")
  comments             Comment[]
  activities           Activity[]
  sentInvites          Invite[]          @relation("InviteSentBy")
  receivedInvites      Invite[]          @relation("InviteReceivedBy")
  pagePresence         PagePresence[]
  uploadedMedia        Media[]
  notifications        Notification[]
  agentJobs            AgentJob[]

  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// NEXTAUTH ADAPTER MODELS
// ─────────────────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────
// WORKSPACE
// Top-level isolation boundary – each team gets their own workspace.
// ─────────────────────────────────────────────────────────────────────────────

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique // URL-safe identifier e.g. "acme-corp"
  description String?  @db.Text
  logo        String?  // URL or emoji
  domain      String?  @unique // custom domain support
  isPersonal  Boolean  @default(false)
  plan        String   @default("free") // free | pro | enterprise
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId String
  owner   User   @relation("WorkspaceOwner", fields: [ownerId], references: [id])

  members     WorkspaceMember[]
  pages       Page[]
  invites     Invite[]
  settings    WorkspaceSettings?
  activities  Activity[]
  media       Media[]
  databases   Database[]
  integrations Integration[]
  agentJobs     AgentJob[]
  agentTriggers AgentTrigger[]

  @@map("workspaces")
}

model WorkspaceSettings {
  id                    String   @id @default(cuid())
  workspaceId           String   @unique
  allowPublicPages      Boolean  @default(false)
  allowGuestEditing     Boolean  @default(false)
  allowMemberInvites    Boolean  @default(true)
  defaultPagePermission Role     @default(EDITOR)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_settings")
}

// ─────────────────────────────────────────────────────────────────────────────
// WORKSPACE MEMBER
// Junction table handling RBAC within a workspace.
// ─────────────────────────────────────────────────────────────────────────────

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        Role     @default(EDITOR)
  joinedAt    DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

// ─────────────────────────────────────────────────────────────────────────────
// INVITE
// Token-based workspace invitation system.
// ─────────────────────────────────────────────────────────────────────────────

model Invite {
  id          String       @id @default(cuid())
  token       String       @unique @default(cuid())
  workspaceId String
  email       String?      // null = open link for anyone
  role        Role         @default(EDITOR)
  status      InviteStatus @default(PENDING)
  expiresAt   DateTime
  maxUses     Int?         // null = unlimited
  useCount    Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  invitedById   String
  invitedUserId String?

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy   User      @relation("InviteSentBy", fields: [invitedById], references: [id])
  invitedUser User?     @relation("InviteReceivedBy", fields: [invitedUserId], references: [id])

  @@map("invites")
}

// ─────────────────────────────────────────────────────────────────────────────
// PAGE
// Core content unit. Self-referencing for infinite nesting.
// Content stored as TipTap JSON (ProseMirror document JSON).
// ─────────────────────────────────────────────────────────────────────────────

model Page {
  id          String   @id @default(cuid())
  title       String   @default("Untitled")
  content     Json?    // TipTap/ProseMirror JSON document
  contentText String?  @db.Text // plain-text for full-text search
  emoji       String?  // page icon emoji e.g. "📄"
  iconType    PageIconType @default(EMOJI)
  iconValue   String?  // emoji char or URL or lucide icon name
  coverImage  String?  // URL to header image
  isPublished Boolean  @default(false)
  isFavorite  Boolean  @default(false)
  isArchived  Boolean  @default(false)
  isTemplate  Boolean  @default(false)
  sortOrder   Float    @default(0) // fractional indexing for drag-drop reorder
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Self-referencing for infinite nesting
  parentId String?
  parent   Page?   @relation("PageChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children Page[]  @relation("PageChildren")

  createdById String
  createdBy   User   @relation("PageCreatedBy", fields: [createdById], references: [id])

  lastEditedById String?
  lastEditedBy   User?   @relation("PageLastEditedBy", fields: [lastEditedById], references: [id])

  comments   Comment[]
  activities Activity[]
  pageMedia  PageMedia[]
  presence   PagePresence[]
  versions   PageVersion[]
  permissions PagePermission[]

  @@index([workspaceId])
  @@index([parentId])
  @@index([isArchived])
  @@index([isPublished])
  @@map("pages")
}

// ─────────────────────────────────────────────────────────────────────────────
// PAGE VERSION
// Stores historical snapshots of page content for version history.
// ─────────────────────────────────────────────────────────────────────────────

model PageVersion {
  id        String   @id @default(cuid())
  pageId    String
  content   Json     // full TipTap JSON snapshot
  title     String
  createdAt DateTime @default(now())
  authorId  String

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId, createdAt])
  @@map("page_versions")
}

// ─────────────────────────────────────────────────────────────────────────────
// PAGE PERMISSION
// Fine-grained per-page ACL overriding workspace-level role.
// ─────────────────────────────────────────────────────────────────────────────

model PagePermission {
  id          String   @id @default(cuid())
  pageId      String
  userId      String
  role        Role
  createdAt   DateTime @default(now())

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, userId])
  @@map("page_permissions")
}

// ─────────────────────────────────────────────────────────────────────────────
// PAGE PRESENCE
// Tracks which users are currently viewing/editing a page (ephemeral).
// Rows are upserted by the WebSocket server and cleared on disconnect.
// ─────────────────────────────────────────────────────────────────────────────

model PagePresence {
  id        String   @id @default(cuid())
  pageId    String
  userId    String
  socketId  String
  cursor    Json?    // { anchor: number, head: number }
  updatedAt DateTime @updatedAt

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pageId, userId])
  @@map("page_presence")
}

// ─────────────────────────────────────────────────────────────────────────────
// COMMENT
// Threaded comments anchored to a page (or a specific block via blockId).
// ─────────────────────────────────────────────────────────────────────────────

model Comment {
  id         String   @id @default(cuid())
  content    String   @db.Text
  blockId    String?  // TipTap block/node ID for inline comments
  isResolved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  pageId String
  page   Page   @relation(fields: [pageId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  parentId String?
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies  Comment[] @relation("CommentReplies")

  @@index([pageId])
  @@map("comments")
}

// ─────────────────────────────────────────────────────────────────────────────
// MEDIA
// Uploaded files – supports local storage and S3 switching via storageType.
// ─────────────────────────────────────────────────────────────────────────────

model Media {
  id          String    @id @default(cuid())
  name        String
  originalName String
  mimeType    String
  size        Int       // bytes
  url         String    // public-facing URL
  storageKey  String    // local path or S3 key
  storageType String    @default("local") // "local" | "s3"
  mediaType   MediaType
  width       Int?
  height      Int?
  createdAt   DateTime  @default(now())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id])

  pageMedia PageMedia[]

  @@index([workspaceId])
  @@map("media")
}

// Junction: pages ↔ media (a page can use many media, media can appear in many pages)
model PageMedia {
  pageId  String
  mediaId String

  page  Page  @relation(fields: [pageId], references: [id], onDelete: Cascade)
  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@id([pageId, mediaId])
  @@map("page_media")
}

// ─────────────────────────────────────────────────────────────────────────────
// DATABASE (Voltaic-style inline databases / tables)
// Lightweight structured data alongside pages.
// ─────────────────────────────────────────────────────────────────────────────

model Database {
  id          String   @id @default(cuid())
  name        String
  schema      Json     // column definitions: [{id, name, type, options}]
  defaultView String   @default("table") // "table" | "board" | "calendar"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  rows DatabaseRow[]

  @@map("databases")
}

model DatabaseRow {
  id         String   @id @default(cuid())
  databaseId String
  data       Json     // { columnId: value }
  sortOrder  Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  database Database @relation(fields: [databaseId], references: [id], onDelete: Cascade)

  @@index([databaseId])
  @@map("database_rows")
}

// ─────────────────────────────────────────────────────────────────────────────
// ACTIVITY
// Audit log for the workspace activity feed.
// ─────────────────────────────────────────────────────────────────────────────

model Activity {
  id          String       @id @default(cuid())
  type        ActivityType
  metadata    Json?        // arbitrary context: { pageTitle, oldRole, newRole, ... }
  createdAt   DateTime     @default(now())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  pageId String?
  page   Page?   @relation(fields: [pageId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@map("activities")
}

// ─────────────────────────────────────────────────────────────────────────────
// NOTIFICATION
// In-app notification inbox per user.
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  title     String
  body      String
  link      String?  // relative URL to navigate on click
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

// ─────────────────────────────────────────────────────────────────────────────
// INTEGRATION
// Connectors to third-party services (e.g., Slack, Google Workspace).
// ─────────────────────────────────────────────────────────────────────────────

model Integration {
  id          String   @id @default(cuid())
  workspaceId String
  provider    String   // "slack" | "google"
  status      String   // "CONNECTED" | "DISCONNECTED"
  accessToken String?  @db.Text
  connectedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, provider])
  @@map("integrations")
}

// ─────────────────────────────────────────────────────────────────────────────
// WAITLIST ENTRY
// Stores early-adopter subscriptions.
// ─────────────────────────────────────────────────────────────────────────────

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@map("waitlist_entries")
}

// =============================================================================
// BACKGROUND AGENT MODELS
// =============================================================================

model AgentJob {
  id          String      @id @default(cuid())
  workspaceId String
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      String      // PENDING, RUNNING, COMPLETED, FAILED, ABORTED, TIMEOUT
  triggerType String      // MANUAL, SCHEDULE, WEBHOOK
  tokenUsage  Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  startedAt   DateTime?
  finishedAt  DateTime?
  steps       AgentStep[]

  @@index([workspaceId])
  @@index([status])
  @@map("agent_jobs")
}

model AgentStep {
  id          String    @id @default(cuid())
  jobId       String
  job         AgentJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  name        String    // E.g., "readWorkspacePage", "writeToPage", "searchWorkspaceMetadata"
  status      String    // PENDING, EXECUTING, SUCCESS, FAILED
  input       String?   @db.Text // JSON payload of step inputs
  output      String?   @db.Text // JSON/Text output of the action
  error       String?   @db.Text // Complete exception detail / stderr
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?

  @@index([jobId])
  @@map("agent_steps")
}

model AgentTrigger {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  type        String    // SCHEDULE, MANUAL, WEBHOOK
  config      String    @db.Text // JSON stringified configuration (cron, keys, etc.)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId])
  @@map("agent_triggers")
}


