# Required Environment Variables for RTX Notion

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/rtxnotion"

# ─── NextAuth.js ─────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="your-32-char-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── WebSocket Server ────────────────────────────────────────────────────────
WS_PORT=3001
NEXT_PUBLIC_WS_URL="http://localhost:3001"

# ─── OAuth Providers (optional) ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ─── File Storage ────────────────────────────────────────────────────────────
UPLOAD_DIR="./public/uploads"
